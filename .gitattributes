# すべてのテキストファイルをリポジトリ内では LF で保存する
* text=auto eol=lf

# 明示的に LF を強制するファイル
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
*.pro       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
gradlew     text eol=lf

# Windows バッチファイルは CRLF を維持
*.bat       text eol=crlf
*.cmd       text eol=crlf

# バイナリファイルは変換しない
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.jar       binary
*.keystore  binary
*.jks       binary

